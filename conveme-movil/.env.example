# Variables de entorno de ConVeMe Mobile
# Copia este archivo como .env y completa los valores

# URL de la API GraphQL (producción)
EXPO_PUBLIC_API_URL=https://api-conveme.utvt.cloud:3000/graphql

# Nombre de la app
EXPO_PUBLIC_APP_NAME=ConVeMe

# Versión de la app
EXPO_PUBLIC_APP_VERSION=1.0.0

# Ambiente (development | staging | production)
EXPO_PUBLIC_ENV=development
